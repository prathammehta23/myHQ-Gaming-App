rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return signedIn() && (
        request.auth.token.email in [
          'admin@myhq.in'
        ] || request.auth.token.email.matches('.*@myhq\.in$')
      );
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
    }

    match /prizes/{prizeId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
    }

    match /winners/{winnerId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
    }

    match /mini_game_scores/{scoreId} {
      allow read: if isAdminEmail();
      allow create: if
        request.resource.data.keys().hasOnly(['game', 'name', 'email', 'score', 'timestamp', 'recordedAt']) &&
        request.resource.data.game is string &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.score is number &&
        request.resource.data.timestamp is number &&
        request.resource.data.recordedAt is string &&
        request.resource.data.game in ['sudoku', 'zip', 'cross', 'simon', 'tap', 'reaction', 'pairs', 'math'];
      allow update, delete: if isAdminEmail();
    }

    match /players/{playerId} {
      allow create, update: if
        request.resource.data.email == playerId
        && request.resource.data.keys().hasOnly(['name', 'email', 'city', 'dept', 'joined'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.city is string
        && request.resource.data.dept is string
        && request.resource.data.joined is string;
      allow read, delete: if isAdminEmail();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
